# Django Environment Variables for Production
# Copy this file to .env and update the values

# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False
DJANGO_SETTINGS_MODULE=backend.production

# Allowed Hosts (comma separated)
ALLOWED_HOSTS=zainussunnaacademy.com,www.zainussunnaacademy.com,api.zainussunnaacademy.com,zainussunna-backend.onrender.com,*.onrender.com

# CORS (comma separated)
CORS_ALLOWED_ORIGINS=https://zainussunnaacademy.com,https://www.zainussunnaacademy.com

# Database - provided by Render automatically as DATABASE_URL
# No need to set this manually

# Static & Media
# STATIC_ROOT and MEDIA_ROOT are set in settings.py

