# Django Secret Key - REQUIRED (generate a secure random key)
# Run: python -c "import secrets; print(secrets.token_hex(50))"
DJANGO_SECRET_KEY=your-secret-key-here

# Debug mode - Set to 'False' in production!
DEBUG=False

# Allowed Hosts - comma-separated list of domains
ALLOWED_HOSTS=zainussunnaacademy.com,www.zainussunnaacademy.com,api.zainussunnaacademy.com

# CSRF Trusted Origins - comma-separated list of HTTPS URLs
CSRF_TRUSTED_ORIGINS=https://zainussunnaacademy.com,https://www.zainussunnaacademy.com,https://api.zainussunnaacademy.com

# CORS Allowed Origins - comma-separated list
CORS_ALLOWED_ORIGINS=https://zainussunnaacademy.com,https://www.zainussunnaacademy.com

# Database - Render provides DATABASE_URL automatically
# Leave empty to use SQLite (development only)
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Or use individual PostgreSQL settings (if not using DATABASE_URL)
# DB_HOST=localhost
# DB_NAME=zainussunna
# DB_USER=postgres
# DB_PASSWORD=your-password
# DB_PORT=5432

